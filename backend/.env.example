# ============================================================
# .env.example — Copier ce fichier en .env et remplir les valeurs
# ============================================================

# Application
DEBUG=true
ENVIRONMENT=development
SECRET_KEY=changez-moi-min-32-caracteres-aleatoires

# Base de données PostgreSQL
DATABASE_URL=postgresql+asyncpg://VOTRE_USER:VOTRE_PASSWORD@localhost:5432/rag_platform

# LLM — Mode par défaut : local | mistral | gemini
DEFAULT_LLM_MODE=gemini

# Ollama (mode local — VPS ou machine locale)
LOCAL_LLM_BASE_URL=http://VOTRE_IP_OLLAMA:11434/v1
LOCAL_LLM_MODEL_NAME=qwen2.5:3b-instruct
VLLM_BASE_URL=http://VOTRE_IP_OLLAMA:11434/v1
VLLM_MODEL_NAME=qwen2.5:3b-instruct
VLLM_MAX_TOKENS=400
VLLM_TEMPERATURE=0.0
VLLM_TIMEOUT=120
VLLM_NUM_CTX=4096

# APIs Cloud (optionnel — pour modes Gemini et Mistral)
GEMINI_API_KEY=votre-cle-google-gemini
GEMINI_MODEL_NAME=gemini-2.5-flash
MISTRAL_API_KEY=votre-cle-mistral
MISTRAL_MODEL_NAME=mistral-small-latest

# Embeddings + RAG
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
RERANKER_MODEL=cross-encoder/mmarco-mMiniLMv2-L12-H384-v1
RERANKER_TOP_K=5
CHUNK_SIZE=800
CHUNK_OVERLAP=150
TOP_K_RESULTS=15
SIMILARITY_THRESHOLD=0.15
MAX_CONTEXT_CHARS=16000

# Admin par défaut (admin_test_actuel)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=VOTRE_MOT_DE_PASSE_ADMIN
